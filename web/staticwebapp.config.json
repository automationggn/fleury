{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://fleury-test-nodejs-01.azurewebsites.net/api/*"
    },
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}
